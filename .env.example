# ============================================================================
#  Tracepoint - environment template
#  Copy to .env and set LLM_API_KEY to your own free Groq key
#  (https://console.groq.com). Everything else can stay as-is.
#  100% FREE, self-hosted, open-source: Groq LLM + local FastEmbed + Postgres.
# ============================================================================

# ----- LLM: Groq via LiteLLM -----------------------------------------------
LLM_PROVIDER=custom
LLM_MODEL=groq/llama-3.3-70b-versatile
LLM_ENDPOINT=https://api.groq.com/openai/v1
LLM_API_KEY=gsk_REPLACE_ME_WITH_YOUR_GROQ_KEY
LLM_TEMPERATURE=0.0
LLM_MAX_COMPLETION_TOKENS=16384
# json_mode is required for Groq. Do NOT use json_schema_mode (cognify aborts).
LLM_INSTRUCTOR_MODE=json_mode

# ----- Groq free-tier rate-limit guards ------------------------------------
LLM_RATE_LIMIT_ENABLED=true
LLM_RATE_LIMIT_REQUESTS=25
LLM_RATE_LIMIT_INTERVAL=60

# Per-file ingest ceiling (seconds): a file whose add+cognify (incl. retries)
# exceeds this is marked failed and the queue moves on. Raise for very large files.
INGEST_FILE_TIMEOUT_S=180

# ----- Embeddings: LOCAL FastEmbed (FREE, never OpenAI) --------------------
# EMBEDDING_DIMENSIONS MUST be set (unset -> 3072 -> silent OpenAI fallback).
EMBEDDING_PROVIDER=fastembed
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
EMBEDDING_DIMENSIONS=384

# ----- Storage: self-hosted PostgreSQL 17 + pgvector (Config A) ------------
USE_UNIFIED_PROVIDER=pghybrid
DB_PROVIDER=postgres
DB_HOST=postgres
DB_PORT=5432
DB_USERNAME=cognee
DB_PASSWORD=cognee
DB_NAME=cognee_db

VECTOR_DB_PROVIDER=pgvector
VECTOR_DB_HOST=postgres
VECTOR_DB_PORT=5432
VECTOR_DB_NAME=cognee_db
VECTOR_DB_USERNAME=cognee
VECTOR_DB_PASSWORD=cognee
VECTOR_DB_URL=postgresql://cognee:cognee@postgres:5432/cognee_db

GRAPH_DATABASE_PROVIDER=postgres
GRAPH_DATABASE_HOST=postgres
GRAPH_DATABASE_PORT=5432
GRAPH_DATABASE_NAME=cognee_db
GRAPH_DATABASE_USERNAME=cognee
GRAPH_DATABASE_PASSWORD=cognee

# ----- Single-user mode ----------------------------------------------------
ENABLE_BACKEND_ACCESS_CONTROL=false
CACHING=false
TEMPORAL_COGNIFY=false

# ----- Startup / logging ---------------------------------------------------
COGNEE_SKIP_CONNECTION_TEST=true
LOG_LEVEL=INFO

# Do NOT set OPENAI_API_KEY. The backend hard-fails on startup if it is present.
